PORT=5000
# Set to "production" on the host so the server serves the built React app.
NODE_ENV=production

# Database (MySQL)
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASS=your-db-password
DB_NAME=daily_tasks_db
# Hosted MySQL needs TLS. Set true on the host (TiDB/Aiven/Railway/PlanetScale).
DB_SSL=false
# Set false only if the provider uses a self-signed CA (e.g. Aiven w/o CA file).
DB_SSL_REJECT_UNAUTHORIZED=true

# Auth — change this to a long random string
JWT_SECRET=change-this-to-a-long-random-string

# Email (Resend — optional). Without a verified domain, mail only reaches your own inbox.
RESEND_API_KEY=re_your_key_here
# Verified sender once you add a domain in Resend (falls back to onboarding@resend.dev).
MAIL_FROM=Daily Devotional <onboarding@resend.dev>

# Public origin of the deployed app (used for CORS + email links).
CLIENT_URL=https://your-app.onrender.com
